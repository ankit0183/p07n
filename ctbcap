grab_stream() {
	local FFMPEG_BASEVER="5.0"

	[ -n "${RECORDING_IGNORE_PROXY}" ] && { local EXT_FFMPEG_OPT="${EXT_FFMPEG_OPT} "'-http_proxy 0'; }

	case ${PLATFORM} in
	chaturbate)
		local CB_REFERER='Referer: https://chaturbate.com/'
		local CB_ORIGIN='Origin: https://chaturbate.com/'
		local EXT_FFMPEG_OPT="${EXT_FFMPEG_OPT} "'-headers "${CB_REFERER}" -headers "${CB_ORIGIN}"'
	;;
	stripchat)
		local SC_REFERER='Referer: https://stripchat.com/'
		local SC_ORIGIN='Origin: https://stripchat.com/'
		local EXT_FFMPEG_OPT="${EXT_FFMPEG_OPT} "'-headers "${SC_REFERER}" -headers "${SC_ORIGIN}"'
	;;
	esac

	local FFMPEG_OPT="$(
		cat <<-'EOT'
			-y -loglevel warning -nostdin
			-copyts -start_at_zero
			-copy_unknown
			-user_agent "${UA}"
			-tls_verify 0
			-fflags +genpts+nobuffer
		EOT
	)${EXT_FFMPEG_OPT}"

	# shellcheck disable=2089
	local FFMPEG_IN='-i "${STREAM_URL}"'

	[ -n "${FFMPEG_CODEC}" ] || local FFMPEG_CODEC='-codec copy'

	local CAPTURE_TIME="$(date "+%Y%m%d-%H%M%S")"

	local FFMPEG_OUT='"${SAVE_PATH}/${MODEL}-${CAPTURE_TIME}.mp4"'
	[ -n "${CUT_TIME}" ] && local FFMPEG_OUT="$(
		cat <<-'EOT'
			-f segment
				-segment_time "${CUT_TIME}"
				-segment_start_number 1
				-reset_timestamps 1
				"${SAVE_PATH}/${MODEL}-${CAPTURE_TIME}_%03d.mp4"
		EOT
	)"

	local FFMPEG_EXEC=ffmpeg

	set -f
	# shellcheck disable=2086,2090
	set -- ${FFMPEG_OPT} ${FFMPEG_IN} ${FFMPEG_CODEC} ${FFMPEG_OUT}
	set +f

	# Cooking ${FFMPEG_EXEC} to directly executable format.
	local _ARG; for _ARG in "$@"; do
		local _OPT_RAW="${_ARG}"
		local _OPT="$(eval echo "${_ARG}")"
		[ "${_OPT_RAW}" = "${_OPT}" ] && { local FFMPEG_EXEC="${FFMPEG_EXEC} ${_OPT_RAW}"; } || {
			local _OPT="$(echo "${_OPT}" | sed "s|'|'\\\''|g; s|.*|'&'|")"
			local FFMPEG_EXEC="${FFMPEG_EXEC} ${_OPT}"
		}
	done

	[ -n "${LINK_MODE}" ] && {
		log "Direct Executable Command for FFmpeg (${FFMPEG_BASEVER}+):"
		log "${FFMPEG_EXEC}"
		return 0
	}

	echo
	echo "8================= [${CAPTURE_TIME}] =================D"
	echo "Direct Executable Command for FFmpeg (${FFMPEG_BASEVER}+):"
	echo "${FFMPEG_EXEC}"
	echo

	sh -c "${FFMPEG_EXEC}" #Launch FFmpeg
}

watchdog() {
	while true; do
		init_path -f "${WATCHDOG_LOGFILE}:10000" "${FFMPEG_LOGFILE}:20000"
		unset EXT_FFMPEG_OPT && fetch_m3u
		# See the notes above fetch_m3u() .
		case ${STREAM_STAT} in
		OK)
			init_path -d "${SAVE_PATH}:${SAVE_PATH_SPACE}" "${LOG_PATH}:${LOG_PATH_SPACE}" \
				&& { utils check_ffmpeg_ver; case $? in 0|2) true ;; *) false ;; esac; } \
				|| { utils nap "10 min" 480 720; continue; }
			log "Now Start Recording..."
			while true; do
				[ -n "${DEBUG_MODE}" ] \
					&& { grab_stream 2>&1 | tee -a "${FFMPEG_LOGFILE}" 2>/dev/null; true; } \
					|| { grab_stream 2>&1 | tee -a "${FFMPEG_LOGFILE}" >/dev/null 2>&1; }
			log "Recording Interrupted..."
				init_path -d "${SAVE_PATH}:${SAVE_PATH_SPACE}" "${LOG_PATH}:${LOG_PATH_SPACE}" || break
				unset EXT_FFMPEG_OPT && fetch_m3u >/dev/null 2>&1 && {
					sleep 2
					log "Restart recording..." && continue
				} || {
					log "Stream closed..."
					utils nap "5 min" 240 360
					log "Try reconnect..."
					break
				}
			done
		;;
		NO_URL) utils nap "10 min" 480 720 ;;
		NAME_CHANGE) utils nap "5 sec" 4 6 ;;
		WRONG_ROOM) utils nap "1 hr" 3300 3900 ;;
		BAD_URL) utils nap "3 min" 150 210 ;;
		*) utils nap "12 hr" 39600 46800 ;;
		esac
	done
}

{ # Execution Entry
	trap '[ -z "${NOBANNER}" ] && exec printf "\n%s\n\n" "BYE (. )( .) BYE" || exec true' HUP INT QUIT TERM

	world "$@"
	case $? in
	0) ;; 2) mgn; exit 0 ;; 3) exit 0 ;; *)
		echo >&2 "See [ $0 -h ] for Command Help."
		mgn >&2; exit 1
	;;
	esac

	[ -n "${DEBUG_MODE}" ] && set -x # Debug Mode

	utils check_depend curl || { mgn >&2; exit 1; }

	[ -n "${LINK_MODE}" ] && {
		fetch_m3u
		case ${STREAM_STAT} in
		NAME_CHANGE)
			sleep "$(utils random_num 4 6)"
			fetch_m3u || { mgn >&2; exit 1; }
		;; OK) ;; *) mgn >&2; exit 1 ;; esac
		grab_stream && { mgn; exit 0; }
	}

	utils check_depend ffmpeg || { mgn >&2; exit 1; }
	utils check_ffmpeg_ver; case $? in 1) mgn >&2; exit 1 ;; esac

	init_path -d "${SAVE_PATH}:${SAVE_PATH_SPACE}" "${LOG_PATH}:${LOG_PATH_SPACE}" || { mgn >&2; exit 1; }
	init_path -f "${WATCHDOG_LOGFILE}:" "${FFMPEG_LOGFILE}:" || { mgn >&2; exit 1; }

	[ -n "${EDGING_MODE}" ] && {
		EDGING_TIME="$(utils random_num 0 600)"
		log "(NOTICE) Edging Mode is On. Delay [${EDGING_TIME}]s before start simping..."
		sleep "${EDGING_TIME}" && unset EDGING_TIME
	}

	watchdog 2>&1 | tee -a "${WATCHDOG_LOGFILE}" 2>/dev/null
}

exit 0
