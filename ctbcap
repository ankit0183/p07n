# World Init
world() {
	unset NO_INPUT SHOW_HELP SHOW_VER ERRIPT
	[ -z "$1" ] && [ -z "${MODEL}" ] && {
		NO_INPUT=1
		SHOW_HELP=1
	}
	while getopts ':c:def:hlo:p:v' OPT; do
		case ${OPT} in
		c) [ -z "${OPTARG##"-"*}" ] && ERRIPT=${OPT} || CUT_TIME=${OPTARG} ;;
		d) DEBUG_MODE=1 ;;
		e) EDGING_MODE=1 ;;
		f) [ -z "${OPTARG##"-"*}" ] && ERRIPT=${OPT} || SAVE_PATH=${OPTARG} ;;
		h) SHOW_HELP=1 ;;
		l) LINK_MODE=1 ;;
		o) [ -z "${OPTARG##"-"*}" ] && ERRIPT=${OPT} || LOG_PATH=${OPTARG} ;;
		p) [ -z "${OPTARG##"-"*}" ] && ERRIPT=${OPT} || PLATFORM=${OPTARG} ;;
		v) SHOW_VER=1 ;;
		\?) ERRIPT=${ERRIPT}${OPTARG} ;;
		:)
			case ${OPTARG} in
			c) ERRIPT=c ;;
			f) ERRIPT=f ;;
			o) ERRIPT=o ;;
			p) ERRIPT=p ;;
			esac
		;;
		esac
	done
	shift $((OPTIND - 1))
	[ -n "$2" ] && { shift 1; [ -z "${ERRIPT}" ] && ERRIPT=-; }
	[ -n "$1" ] && MODEL=$1

	defaulting_args

	[ -z "${NOBANNER}" ] && {
		mgn
		[ "1${SHOW_HELP}" -ge "1${SHOW_VER}" ] && { doc neon; echo; } # show banner, unless in version mode
		[ -n "${BANNER}" ] && return 3
	}
	[ -n "${ERRIPT}" ] && {
		case ${ERRIPT} in
		c) msg >&2 "(ERROR) -c: No Cut Time Specified!" ;;
		f) msg >&2 "(ERROR) -f: No Recording Saving Path Specified!" ;;
		o) msg >&2 "(ERROR) -o: No Log Saving Path Specified!" ;;
		p) msg >&2 "(ERROR) -p: No Platform Specified!" ;;
		-) msg >&2 "(ERROR) Invalid Input: $(echo "$*" | sed 's|\([^[:space:]]\+\)|[\1]|g') !" ;;
		*) msg >&2 "(ERROR) Invalid Option: $(echo "${ERRIPT}" | sed 's|.|[&] |g')!" ;;
		esac
		return 1
	}
	[ "$(uname -s | tr '[:upper:]' '[:lower:]')" != "linux" ] && [ -z "${TERMUX_VERSION}" ] && {
		msg "(NOTICE) Non-GNU/Linux OS detected! Make sure you have coreutils installed! Or You Will Get Error!"
	}
	[ -n "${TERMUX_VERSION}" ] && {
		msg "(NOTICE) Termux detected! Make sure you have 'coreutils' installed (pkg install coreutils)."
	}
	[ -n "${NO_INPUT}" ] && {
		msg "(NOTICE) No Option Specified! Show Help Message..."
	}
	[ -n "${SHOW_HELP}" ] && { doc help; return 2; }
	[ -n "${SHOW_VER}" ] && { doc ver; return 2; }

	[ -z "${MODEL}" ] && { msg >&2 "(ERROR) No Username or URL Specified!"; return 1; }
	local _MODEL="$(basename -- "${MODEL}" 2>/dev/null | head -n 1 | tr '[:upper:]' '[:lower:]' | grep -oE '^[a-z0-9_-]+$')"
	[ -z "${_MODEL}" ] && { msg >&2 "(ERROR) Invalid Username or URL! [${MODEL}]"; return 1; }
	MODEL=${_MODEL}

	PLATFORM=$(echo "${PLATFORM}" | tr '[:upper:]' '[:lower:]')
	case ${PLATFORM} in
	chaturbate|ctb|cb) PLATFORM=chaturbate ;;
	stripchat|stc|sc|st) PLATFORM=stripchat ;;
	*) msg >&2 "(ERROR) Unknown Platform: [${PLATFORM}] !"; return 1 ;;
	esac

	[ "${CUT_TIME}" = 0 ] && unset CUT_TIME || {
		local _CUT_TIME="$(echo "${CUT_TIME}" | head -n 1 | grep -oE '^[0-9]+$')"
		printf %d "${_CUT_TIME}" >/dev/null 2>&1 || {
			msg >&2 "(ERROR) Cut Time Must be Some INT Number! [${CUT_TIME}]"
			return 1
		}
		CUT_TIME=${_CUT_TIME}
	}

	SAVE_PATH="$(echo "${SAVE_PATH}" | sed "s|^~/|${HOME}/|")"
	LOG_PATH="$(echo "${LOG_PATH}" | sed "s|^~/|${HOME}/|")"
	_SAVE_PATH=$(readlink -f -- "${SAVE_PATH}" 2>/dev/null || realpath -- "${SAVE_PATH}" 2>/dev/null || echo "${SAVE_PATH}")
	SAVE_PATH=${_SAVE_PATH}
	[ "${LOG_PATH}" = 0 ] && {
		unset LOG_PATH
		msg "(NOTICE) Log saving is Disabled."
		WATCHDOG_LOGFILE="/dev/null"
		FFMPEG_LOGFILE="/dev/null"
	} || {
		_LOG_PATH=$(readlink -f -- "${LOG_PATH}" 2>/dev/null || realpath -- "${LOG_PATH}" 2>/dev/null || echo "${LOG_PATH}")
		LOG_PATH=${_LOG_PATH}
		WATCHDOG_LOGFILE="${LOG_PATH}/${MODEL}-${PLATFORM}.log"
		FFMPEG_LOGFILE="${LOG_PATH}/${MODEL}-${PLATFORM}.ffmpeg.log"
	}

	[ -z "${NOBANNER}" ] && msg ">> Simping [${MODEL}] (${PLATFORM})"

	return 0
}

# Power Tools
utils() {
	case $1 in
	# Usage: `utils connect_stat "<URL>"`
	connect_stat)
		curl "$2" \
			-4 -L -s -I \
			-A "${UA}" \
			--compressed \
			--connect-timeout 5 --retry 5 --retry-delay 2 \
			2>/dev/null | tr -d '\r' | head -n 1 | grep -oE '[0-9]{3}' \
			|| echo 999
	;;
	# Usage: `utils connect_dump "<URL>"`
	connect_dump)
		curl "$2" \
			-4 -L -s -i\
			-A "${UA}" \
			--compressed \
			--connect-timeout 5 --retry 5 --retry-delay 2 \
			2>/dev/null | tr -d '\r'
	;;
	# Reuse results of connect_dump to get HTTP status code at the time.
	# Usage: `utils dump2stat "<URL DUMP>"`
	dump2stat)
		echo "$2" \
			| head -n 1 \
			| cut -c -15 \
			| grep -oE '[0-9]{3}' \
			|| echo 999
	;;
	# Re-implement random num tool on POSIX Shell (B/E).
	# Usage: `utils random_num <SNUM> <BNUM>`
	random_num)
		local SNUM="$2" # INT. Must >= 0. Small-end of Random Num you want.
		local BNUM="$3" # INT. Must < (2^32)/2. Big-end of Random Num you want.
		local BNUM=$(( BNUM + 1 )) # Add ${BNUM} to the pool, make method become B/E Random.
		local RSEED="$(od -An -N4 -tu4 /dev/urandom)" # Gen random num B/E 0 - (2^32-1) as Seed.
		local SEEDMIN=$(( 4294967295 % ( BNUM - SNUM ) )) # ${SEED} <= ${SEEDMIN} will cause redundant modulus.
		while [ "${RSEED}" -le "${SEEDMIN}" ]; do
			local RSEED="$(od -An -N4 -tu4 /dev/urandom)" # If ${SEED} <= ${SEEDMIN}, Reshake ${RSEED} till isn't.
		done
		echo $(( RSEED % ( BNUM - SNUM ) + SNUM )) # Format Same as $((RANDOM)) in Bash.
	;;
	# Take a nap for a while.
	# Usage: `utils nap "<human time (e.g `10 min`)>" <least time (sec)> <maximum time (sec)>`
	# If no <maximum time> specified, the <least time> will be applied.
	nap)
		[ -n "$4" ] && local NAP_TIME="$(utils random_num "$3" "$4")" || local NAP_TIME="$3"
		log "Sleep for $([ -n "$4" ] && echo "around ")$2... [${NAP_TIME}]"
		sleep "${NAP_TIME}"
	;;
	# Usage: `utils check_depend "<COMMAND>"`
	check_depend)
		command -v "$2" >/dev/null 2>&1 || {
			log >&2 "(ERROR) Command [$2] not found! Check \$PATH or install it."
			return 1
		}
		return 0
	;;
	# Usage:
	# Human-friendly message and return value: `utils check_ffmpeg_ver`
	# Check if version is met and return value: `utils check_ffmpeg_ver "[VERSION CODE]"`
	check_ffmpeg_ver)
		# TODO: Rewrite to more robust FFmpeg version check.
		#       For example, the version code for `n7.1` could also be `N-117180-b08d7969c5`.
		#       Use `git rev-list --count HEAD`, `git rev-parse --short HEAD` to check.

		local REQ_VER=5.0 # Required minimum version of FFmpeg.
		local REC_VER=7.1 # Recommended minimum version of FFmpeg.

		local CUR_VER_RAW="$(ffmpeg -version 2>/dev/null | head -n 1 | tr -s '[:space:]' ' ' | cut -d ' ' -f3)"
		[ -z "${CUR_VER_RAW}" ] && {
			[ -z "$2" ] && log >&2 "(ERROR) NO FFmpeg found! (Recommended ${REC_VER}+)"
			return 1
		}

		case ${CUR_VER_RAW} in
		# Add `-` at the end to avoid version collision
		[!0-9][0-9]*) local CUR_VER="${CUR_VER_RAW#?}-" ;;
		*) local CUR_VER="${CUR_VER_RAW}-" ;;
		esac

		_ver_ge() {
			local _v1="$1" _v2="$2"
			awk -v a="${_v1%-}" -v b="${_v2%-}" 'BEGIN{split(a,A,"."); split(b,B,"."); for(i=1;i<=4;i++){if(int(A[i])<int(B[i])){exit 1}}; exit 0}' 2>/dev/null
		}
		[ -n "$2" ] && {
			local TAR_VER="$2"
			_ver_ge "${CUR_VER}" "${TAR_VER}" && return 0
			return 1
		}
		_ver_ge "${CUR_VER}" "${REQ_VER}" || {
			log >&2 "(ERROR) Version of FFmpeg must be higher than ${REQ_VER}! [${CUR_VER_RAW}] (Better ${REC_VER}+)"
			return 1
		}
		_ver_ge "${CUR_VER}" "${REC_VER}" || {
			log >&2 "(WARNING) Using legacy version of FFmpeg. [${CUR_VER_RAW}] (Better ${REC_VER}+)"
			return 2
		}
		return 0
	;;
	esac
}

# Usage:
# Init dirs: `init_path -d "<DIR1>:<MiB>" "<DIR2>:<MiB>" ...`
# Init files: `init_path -f "<FILE1>:<MAX LINE>" "<FILE2>:<MAX LINE>" ...`
init_path() {
	case $1 in
	-d)
		shift 1
		local _ARG; for _ARG in "$@"; do
			local DIR="$(echo "${_ARG}" | sed 's|:[^:]*$||')"
			[ -z "${DIR}" ] && continue # Skip empty path
			local SPACE="$(echo "${_ARG}" | sed 's|.*:||')"
			[ -z "${SPACE}" ] && local SPACE=0 # No space require
			[ -z "${DIR%"/"}" ] && { log >&2 "(ERROR) Root directory are not allowed!"; return 1; }

			local _DIR="${DIR}"; while [ ! -d "${_DIR}" ]; do # ${DIR} may not created yet
				local _DIR="$(dirname -- "${_DIR}")"
			done
			local FREESPACE="$(( $(df -Pk -- "${_DIR}" | awk 'NR==2 {print $4}') / 1024 ))"
			[ "${FREESPACE}" -lt "${SPACE}" ] && {
				log >&2 "(ERROR) Space on [${_DIR}/] must be bigger than ${SPACE}MiB! [${FREESPACE}MiB]"
				return 1
			}

			mkdir -p -- "${DIR}" >/dev/null 2>&1
			[ ! -e "${DIR}" ] && { log >&2 "(ERROR) Unable to create directory [${DIR}] !"; return 1; }
			[ ! -d "${DIR}" ] && { log >&2 "(ERROR) [${DIR}] is not a directory!"; return 1; }
			[ ! -w "${DIR}" ] && { log >&2 "(ERROR) Unable to write to directory [${DIR}/] !"; return 1; }
			true
		done
	;;
	-f)
		shift 1
		local _ARG; for _ARG in "$@"; do
			local FILE="$(echo "${_ARG}" | sed 's|:[^:]*$||')"
			[ -z "${FILE}" ] && continue # Skip empty path
			[ ! -e "${FILE}" ] && continue # Skip not exist
			[ "${FILE}" = "/dev/null" ] && continue # Skip black hole
			[ ! -f "${FILE}" ] && { log >&2 "(ERROR) [${FILE}] is not a file!"; return 1; }
			[ ! -w "${FILE}" ] && { log >&2 "(ERROR) Unable to write to file [${FILE}] !"; return 1; }

			local LINE="$(echo "${_ARG}" | sed 's|.*:||')"
			[ -z "${LINE}" ] && continue # Skip trimming file
			[ ! -r "${FILE}" ] && {
				log >&2 "(WARNING) Unable to read file [${FILE}] !"
				log >&2 "(WARNING) Skip trimming [${FILE}] due to unreadability."
				continue
			}
			[ "${LINE}" -le 0 ] && { true > "${FILE}"; } >/dev/null 2>&1
			[ "$(wc -l 2>/dev/null < "${FILE}" || echo 0)" -ge "$(( LINE + 2000 ))" ] && { # 2000 as buffer size
				log "Trim [${FILE}] to ${LINE} lines..."
				local _TMPDIR="${TMPDIR:-/tmp}"
				local BUFFER_FILE="${_TMPDIR}/_$(basename -- "${FILE}" 2>/dev/null || echo what_the_fuck)_$(date +%s)"
				tail -n "${LINE}" -- "${FILE}" > "${BUFFER_FILE}"
				cat "${BUFFER_FILE}" > "${FILE}"
				rm -f -- "${BUFFER_FILE}"
			}
		done
	;;
	esac
}

# Core Platform Methods.
# $STREAM_STAT = { OK | NO_URL (init) | NAME_CHANGE | WRONG_ROOM | BAD_URL | TIN_FOIL_HAT }
# with return    { 0  | 1             | 1           | 1          | 1       | 110          }
fetch_m3u() {
	unset STREAM_URL
	[ -n "${MODEL_NEW_NAME}" ] && local MODEL="${MODEL_NEW_NAME}"
	STREAM_STAT=NO_URL # init

	# Core Methods by each Platform.
	case ${PLATFORM} in
	chaturbate)
		# EXT_FFMPEG_OPT="${EXT_FFMPEG_OPT} "'-reconnect_at_eof 1' # experimental
		local API_URL="https://chaturbate.com/api/chatvideocontext/${MODEL}/" # Must keep " / " at the end
		local CONNECT_DUMP="$(utils connect_dump "${API_URL}")"
		local CONNECT_STAT="$(utils dump2stat "${CONNECT_DUMP}")"
		case ${CONNECT_STAT} in
		# Check if online:
		2*)
			local ROOM_STATUS="$(echo "${CONNECT_DUMP}" | grep -oE '"room_status":[ ]?"[^"]+"' | head -n 1 | cut -d '"' -f4)"
			[ -n "$(echo "${CONNECT_DUMP}" | grep -oE 'http[s]?://edge[^ ]+\.m3u8'| head -n 1)" ] && {
				STREAM_URL=$(echo "${CONNECT_DUMP}" | grep -a '"hls_source":' | head -n 1 | sed 's|.*"hls_source": "||; s|".*||')
				# [ "$(utils connect_stat "${STREAM_URL}")" -ge 400 ] && {
				# 	log >&2 "(ERROR) [${MODEL}] is Online now, but looks like the backend of [${PLATFORM}] has been changed."
				# 	unset STREAM_URL && { STREAM_STAT=BAD_URL && return 1; }
				# }
				true
			} || {
				log "[${MODEL}] is [${ROOM_STATUS}] now. [${CONNECT_STAT}]"
				[ -z "${STREAM_LAST_SEEM}" ] && {
					STREAM_LAST_SEEM="$(utils connect_dump "https://chaturbate.com/api/biocontext/${MODEL}/" \
						| grep -oE '"last_broadcast":[ ]?"[^"]+"' \
						| head -n 1 \
						| cut -d '"' -f4 \
						| cut -d '.' -f1 \
						| tr -d ':-' \
						| sed 's|T|-|g' \
						| grep -oE '^[0-9]{8}-[0-9]{6}$' )" \
							&& log "Last streaming at: [${STREAM_LAST_SEEM}] (UTC)" \
							|| {
								log "Last streaming time unknown."
								STREAM_LAST_SEEM=_
							}
				}
				STREAM_STAT=NO_URL && return 1
			}
			unset CONNECT_STAT
		;;
		3*)
			log >&2 "You might gotten blocked by CAPTCHA. [${CONNECT_STAT}]"
			STREAM_STAT=NO_URL && return 1
		;;
		# Check if Model change to new name
		404)
			local CONNECT_DUMP="$(utils connect_dump "https://chaturbate.com/${MODEL}/")"
			local CONNECT_STAT="$(utils dump2stat "${CONNECT_DUMP}")"
			MODEL_NEW_NAME=$(echo "${CONNECT_DUMP}" | grep -oE 'location:[ ]?/[^/]+/' | head -n 1 | cut -d '/' -f2)
			[ -n "${MODEL_NEW_NAME}" ] && {
				log >&2 "(WARNING) [${MODEL}] has changed her name to [${MODEL_NEW_NAME}]. [${CONNECT_STAT}]"
				log "(NOTICE) [${MODEL_NEW_NAME}] will now be used for subsequent requests."
				STREAM_STAT=NAME_CHANGE && return 1
			} || {
				log >&2 "(ERROR) Can't find [${MODEL}] on [${PLATFORM}]. [${CONNECT_STAT}]"
				STREAM_STAT=WRONG_ROOM && return 1
			}
			unset CONNECT_STAT
		;;
		esac
	;;
	stripchat)
		local API_URL="https://stripchat.com/api/front/v2/models/username/${MODEL}/cam"
		local CONNECT_DUMP="$(utils connect_dump "${API_URL}")"
		local CONNECT_STAT="$(utils dump2stat "${CONNECT_DUMP}")"
		case ${CONNECT_STAT} in
		# Check if online:
		2*|3*)
			[ -n "$(echo "${CONNECT_DUMP}" | grep -o '"isCamAvailable":true' | head -n 1)" ] && {
				local STREAMNAME="$(echo "${CONNECT_DUMP}" | grep '"streamName":' | head -n 1 | sed 's|.*"streamName":"||; s|".*||')"
				STREAM_URL="https://edge-hls.sacdnssedge.com/hls/${STREAMNAME}/master/${STREAMNAME}_auto.m3u8"
				local STREAM_URL_STATUS="$(utils connect_stat "${STREAM_URL}")"
				[ "${STREAM_URL_STATUS}" -ge 400 ] && {
					log >&2 "(ERROR) [${MODEL}] is Online, but can't access the stream now. [${STREAM_URL_STATUS}]"
					unset STREAM_URL && { STREAM_STAT=BAD_URL && return 1; }
				}
				true
			} || {
				log "[${MODEL}] is offline/private now. [${CONNECT_STAT}]"
				STREAM_STAT=NO_URL && return 1
			}
			unset CONNECT_STAT
		;;
		# TODO: Name changing detection for Stripchat method.
		esac
	;;
	esac

	case ${CONNECT_STAT} in
	""|2*|3*) ;;
	401) log >&2 "Room [${MODEL}] might require password. [${CONNECT_STAT}]" ; STREAM_STAT=NO_URL && return 1 ;;
	404) log >&2 "(ERROR) Can't find [${MODEL}] on [${PLATFORM}]. [${CONNECT_STAT}]"; STREAM_STAT=WRONG_ROOM && return 1 ;;
	4*) log >&2 "You might gotten blocked by CAPTCHA. [${CONNECT_STAT}]"; STREAM_STAT=NO_URL && return 1 ;;
	999) log >&2 "Internet Connection Error. [${CONNECT_STAT}]"; STREAM_STAT=NO_URL && return 1 ;;
	1*|5*|*) log >&2 "${PLATFORM} Server on failure now. [${CONNECT_STAT}]"; STREAM_STAT=NO_URL && return 1 ;;
	esac

	# If successfully grabbed ${STREAM_URL}, show them.
	[ -n "${STREAM_URL}" ] && {
		log "[${MODEL}] is Online! [$([ -n "${ROOM_STATUS}" ] && echo "${ROOM_STATUS}" || echo online)]"
		log "Stream URL: [${STREAM_URL}]"
		STREAM_STAT=OK && return 0
	} || {
		log "(ERROR) Failed to fetch Stream URL!$([ -n "${CONNECT_STAT}" ] && echo " [${CONNECT_STAT}]")"
		STREAM_STAT=NO_URL && return 1
	}

	log "Logic is dead. Time to Tin Foil Hat."
	STREAM_STAT=TIN_FOIL_HAT && return 110
}

