CTBCAP_RELEASE=r10

# Command Options > Environment Variables > Default Arguments
defaulting_args() {

	# Recorded files saving path
	[ -n "${SAVE_PATH}" ] || SAVE_PATH="${PWD}/ctbcap_rec"
	[ -n "${SAVE_PATH_SPACE}" ] || SAVE_PATH_SPACE=512 # Required disk space by MiB.

	# Log files saving path
	# Disable logging if set to 0.
	[ -n "${LOG_PATH}" ] || LOG_PATH="${SAVE_PATH}/log"
	[ -n "${LOG_PATH_SPACE}" ] || LOG_PATH_SPACE=16 # Required disk space by MiB.

	# Streamer's Username or Room URL.
	[ -n "${MODEL}" ] || MODEL=

	# Platform that streaming at. Choose "chaturbate" or "stripchat".
	[ -n "${PLATFORM}" ] || PLATFORM="chaturbate"

	# Used as number of seconds to cut the recording file in real time.
	# Don't cut if set to 0.
	[ -n "${CUT_TIME}" ] || CUT_TIME=3600

	# https://raw.githubusercontent.com/jtanx/user-agents/refs/heads/main/user-agents.json
	[ -n "${UA}" ] || UA='Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/146.0.0.0 Safari/537.36'

	# Edging Mode.
	# Delay initial requests to servers to avoid time-specific request waves caused by large-scale deployments.
	# Inactive if not 1.
	[ "${EDGING_MODE}" = "1" ] || EDGING_MODE=

	# Debug Mode. Inactive if not 1.
	[ "${DEBUG_MODE}" = "1" ] || DEBUG_MODE=

	# Ignore system proxy while recording.
	[ "${RECORDING_IGNORE_PROXY}" = "1" ] || RECORDING_IGNORE_PROXY=

	# Link Mode. Only grab stream URL. Inactive if not 1.
	[ "${LINK_MODE}" = "1" ] || LINK_MODE=

	# NOBANNER: Disable banner display when in daemon to adapt non-interactive interfaces.
	# BANNER: Show only banner.
	# Inactive if not 1.
	[ "${NOBANNER}" = "1" ] || NOBANNER=
	[ "${BANNER}" = "1" ] || BANNER=
	[ "${BANNER}" -eq "${NOBANNER}" ] 2>/dev/null && unset BANNER NOBANNER # if set both, then neither will active
}

{ # Useful aliases
	alias msg='printf "%s\n\n"' # Message that needs to show before the daemon
	alias mgn='[ -z "${NOBANNER}" ] && printf "\n"' # Bottom margin for better exit look
	alias log='printf "[$(date "+%Y%m%d-%H%M%S")] %s\n"' # Timestamped message
}

